NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: public site URL for links in bidder emails (falls back to VERCEL_URL on Vercel)
NEXT_PUBLIC_SITE_URL=

# Optional: direct invoice email sending via Resend
RESEND_API_KEY=
INVOICE_FROM_EMAIL=info@acrebid.com
# Optional: "from" for bidder email confirmation (defaults to INVOICE_FROM_EMAIL, then info@acrebid.com)
BIDDER_VERIFICATION_FROM_EMAIL=
# Optional: separate "from" for outbid alerts (defaults to INVOICE_FROM_EMAIL)
NOTIFICATION_FROM_EMAIL=
